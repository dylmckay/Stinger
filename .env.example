# Copy to .env and fill in secrets. `docker compose up` reads .env automatically.

# ── Postgres ───────────────────────────────────────────────────────────
POSTGRES_USER=stinger
POSTGRES_PASSWORD=change-me
POSTGRES_DB=stinger

# ── Application ────────────────────────────────────────────────────────
# asyncpg URL. Host `postgres` is the compose service name; the password
# here MUST match POSTGRES_PASSWORD above.
DATABASE_URL=postgresql+asyncpg://stinger:change-me@postgres:5432/stinger

# Signs dashboard session cookies. Generate a fresh one:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-with-a-generated-secret

# ── Delivery tuning (optional — defaults shown) ────────────────────────
# Allow delivery to private/loopback targets (self-hosting to internal
# hosts). Leave false in production; the SSRF guard blocks them otherwise.
ALLOW_PRIVATE=false

# Consecutive endpoint failures before the circuit breaker disables it.
FAILURE_THRESHOLD=20

# Max simultaneous in-flight deliveries per worker.
MAX_CONCURRENCY=50

# Host port the dashboard/API is published on.
API_PORT=8000
