# Copy to .env and edit. docker-compose reads .env automatically.

# --- Postgres (bundled db service; also used to compose DATABASE_URL) ---
POSTGRES_USER=stinger
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=stinger

# --- App ---
# Signs dashboard session cookies. Generate a fresh one for production:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=kwuAHGvwXP6gJAHeVQnY2kcmaHLNxpsvJwQhuC5doEy5SAlulPAGvmtgeT2U1YW5

# Allow delivery to private / loopback IPs. Keep false in production; set true
# only to test against receivers on localhost. (Needs the matching app setting.)
STINGER_ALLOW_PRIVATE=false

# DATABASE_URL is composed from the POSTGRES_* values above. Set it explicitly
# only to point Stinger at an external database instead of the bundled one:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
